# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# macOS local secrets
apps/macos/RaiskasMac/Config.local.plist
apps/ios/CryptoRaiskasIOS/Config.local.plist

# Xcode user/derived local files
**/xcuserdata/
*.xcuserstate
**/build/

# local build artifacts
Release/

# generated PWA artifacts
public/sw.js
public/workbox-*.js

# local tool runtime/cache data
tools/cache/
tools/onchain-monitor/data/
